{
	"info": {
		"_postman_id": "role-permissions-api",
		"name": "Role Permissions API",
		"description": "API untuk mengelola Role Permissions - OJK Orientasi",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api"
		},
		{
			"key": "userNip",
			"value": "admin123"
		},
		{
			"key": "menuId",
			"value": ""
		},
		{
			"key": "roleId",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Menu",
			"item": [
				{
					"name": "1. Get All Menus",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus"]
						}
					}
				},
				{
					"name": "2. Get Menu Tree",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus/tree",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus", "tree"]
						}
					}
				},
				{
					"name": "3. Get Menu by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus/{{menuId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus", "{{menuId}}"]
						}
					}
				},
				{
					"name": "4. Create Menu",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"menu_code\": \"REPORTS\",\n    \"menu_name\": \"Reports\",\n    \"description\": \"Report management menu\",\n    \"parent_id\": null,\n    \"display_order\": 5,\n    \"is_active\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus"]
						}
					}
				},
				{
					"name": "5. Update Menu",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"menu_code\": \"REPORTS\",\n    \"menu_name\": \"Reports Updated\",\n    \"description\": \"Updated description\",\n    \"display_order\": 6,\n    \"is_active\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus/{{menuId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus", "{{menuId}}"]
						}
					}
				},
				{
					"name": "6. Delete Menu",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/menus/{{menuId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "menus", "{{menuId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Permissions",
			"item": [
				{
					"name": "1. Get Permissions by Role",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/permissions/role/{{roleId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "permissions", "role", "{{roleId}}"]
						}
					}
				},
				{
					"name": "2. Create/Update Permission",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role_id\": \"{{roleId}}\",\n    \"menu_id\": \"{{menuId}}\",\n    \"can_view\": true,\n    \"can_create\": true,\n    \"can_update\": true,\n    \"can_delete\": false\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/role-permissions/permissions",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "permissions"]
						}
					}
				},
				{
					"name": "3. Bulk Update Permissions",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role_id\": \"{{roleId}}\",\n    \"permissions\": [\n        {\n            \"menu_id\": \"{{menuId}}\",\n            \"can_view\": true,\n            \"can_create\": true,\n            \"can_update\": false,\n            \"can_delete\": false\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/role-permissions/permissions/bulk",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "permissions", "bulk"]
						}
					}
				},
				{
					"name": "4. Delete Permission",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/permissions/role/{{roleId}}/menu/{{menuId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "permissions", "role", "{{roleId}}", "menu", "{{menuId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Matrix",
			"item": [
				{
					"name": "1. Get Permission Matrix (Single Role)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/matrix/{{roleId}}",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "matrix", "{{roleId}}"]
						}
					}
				},
				{
					"name": "2. Get All Permission Matrices",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/matrix",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "matrix"]
						}
					}
				}
			]
		},
		{
			"name": "Check",
			"item": [
				{
					"name": "1. Check Permission",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-User-Nip",
								"value": "{{userNip}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/role-permissions/check?roleName=Admin&menuCode=PKSI&permissionType=VIEW",
							"host": ["{{baseUrl}}"],
							"path": ["role-permissions", "check"],
							"query": [
								{
									"key": "roleName",
									"value": "Admin"
								},
								{
									"key": "menuCode",
									"value": "PKSI"
								},
								{
									"key": "permissionType",
									"value": "VIEW"
								}
							]
						}
					}
				}
			]
		}
	]
}
