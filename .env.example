# Database Configuration
DB_HOST=localhost
DB_PORT=1433
DB_NAME=pcs8_orientasi
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# LDAP Configuration
LDAP_URL=ldap://your-ldap-server:389
LDAP_BASE=dc=example,dc=com

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-change-this-in-production-min-32-chars
JWT_EXPIRATION=86400000

# RSA Encryption Keys (Base64 encoded)
RSA_PRIVATE_KEY=your_base64_encoded_private_key
RSA_PUBLIC_KEY=your_base64_encoded_public_key

# API Security
API_KEY=your-secure-api-key-here
